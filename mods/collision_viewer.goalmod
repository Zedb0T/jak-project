# Collision Viewer
# Shows collision meshes overlaid on top of the normal game rendering.
# Useful for speedrunning route planning.

@mod
name = "Collision Viewer"
author = "OpenGOAL"
version = "1.0"
description = "Overlays collision mesh geometry on top of normal rendering. Does not remove textures."
game = any

# Must use on_frame because GOAL code overwrites collision flags every frame.
@on_frame
debug.collision_enable = true
debug.collision_wireframe = false
